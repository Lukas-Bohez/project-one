{
  "manifest_version": 3,
  "name": "Lofi Cached Player",
  "version": "0.1",
  "description": "Play local/cached lofi tracks bundled with the extension (cached-only mode).",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lofi Cached Player"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "lofi/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
