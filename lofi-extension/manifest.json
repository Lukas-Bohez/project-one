{
  "manifest_version": 3,
  "name": "Lofi Player",
  "version": "0.2",
  "description": "Simple lofi music player - load a folder of music files to play",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "action": {
    "default_title": "Lofi Player",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
