{
  "manifest_version": 3,
  "name": "Lofi Player",
  "version": "1.0.0",
  "description": "Play lofi music and videos in a standalone window with video support, album art, and full keyboard controls",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Lofi Player"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html", "assets/tracks.json", "lofi/*.mp3", "lofi/*.mp4"],
      "matches": ["<all_urls>"]
    }
  ]
}
