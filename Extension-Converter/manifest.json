{
  "manifest_version": 3,
  "name": "YouTube Video Converter",
  "version": "1.0",
  "description": "Convert YouTube videos and playlists to MP3/MP4 with variable quality",
  "permissions": [
    "activeTab",
    "cookies",
    "tabs",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://api.y2mate.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert YouTube Video"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}