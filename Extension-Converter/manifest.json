{
  "manifest_version": 2,
  "name": "Convert the Spire (Firefox Only)",
  "version": "2.2.0",
  "description": "Convert YouTube videos and playlists to MP3/MP4 with automatic batch processing. Firefox-only due to Manifest V3 download restrictions.",
  "permissions": [
    "activeTab",
    "cookies",
    "tabs",
    "storage",
    "downloads",
    "https://api.y2mate.com/*",
    "https://api.y2meta.com/*",
    "https://api.yt1s.com/*",
    "https://api.yt5s.com/*",
    "https://api.ytmp3.cc/*",
    "*://*.youtube.com/*",
    "https://*.googlevideo.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Convert YouTube Video"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "convert-the-spire@quizthespire.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "optional": [],
        "required": ["none"]
      }
    }
  }
}