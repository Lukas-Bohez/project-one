{
  "manifest_version": 3,
  "name": "Convert the Spire",
  "version": "2.2",
  "description": "Convert YouTube videos and playlists to MP3/MP4 with automatic batch processing",
  "permissions": [
    "activeTab",
    "cookies",
    "tabs",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://api.y2mate.com/*",
    "https://api.y2meta.com/*",
    "https://api.yt1s.com/*",
    "https://api.yt5s.com/*",
    "https://api.ytmp3.cc/*",
    "*://*.youtube.com/*",
    "https://*.googlevideo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert YouTube Video"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}