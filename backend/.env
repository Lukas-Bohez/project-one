# YouTube Download Configuration
# Automatically configured with user cookies

# Maximum retry attempts per download
YTDL_MAX_RETRIES=10

# Retry forever on transient errors?
YTDL_RETRY_FOREVER=false

# Base backoff time in seconds between retries
YTDL_BACKOFF_BASE=2.0

# Maximum backoff time in seconds
YTDL_BACKOFF_MAX=30.0

# Number of worker threads for downloads
YTDL_WORKER_POOL_SIZE=12

# Maximum queue size for pending downloads
YTDL_WORKER_QUEUE_MAX=500

# ⚠️ DISABLED: Cookies were causing 30-60s delays with 403 errors
# Re-enable when you have fresh, working cookies from your logged-in browser
# YTDL_COOKIE_FILE=/home/student/Project/project-one/backend/cookies.txt

# Optional: HTTP/HTTPS proxy for YouTube downloads (uncomment if needed)
# YTDL_PROXY=http://proxy.example.com:8080

# Optional: List of proxies to rotate through (uncomment if needed)
# YTDL_PROXY_LIST=http://proxy1.example.com:8080,http://proxy2.example.com:8080
