# YouTube Download Configuration
# Copy this file to .env and adjust values as needed

# Maximum retry attempts per download (default: 10)
YTDL_MAX_RETRIES=10

# Retry forever on transient errors? (true/false, default: false)
YTDL_RETRY_FOREVER=false

# Base backoff time in seconds between retries (default: 2.0)
YTDL_BACKOFF_BASE=2.0

# Maximum backoff time in seconds (default: 30.0)
YTDL_BACKOFF_MAX=30.0

# Number of worker threads for downloads (default: 12)
YTDL_WORKER_POOL_SIZE=12

# Maximum queue size for pending downloads (default: 500)
YTDL_WORKER_QUEUE_MAX=500

# Optional: HTTP/HTTPS proxy for YouTube downloads
# ⚠️ REQUIRED if your server IP is blocked by YouTube (403 errors)
# YTDL_PROXY=http://proxy.example.com:8080

# Optional: List of proxies to rotate through (comma-separated)
# ⚠️ RECOMMENDED for high-volume usage to avoid IP bans
# YTDL_PROXY_LIST=http://proxy1.example.com:8080,http://proxy2.example.com:8080,socks5://proxy3.example.com:1080

# Optional: Path to YouTube cookies.txt file for authenticated content
# ⚠️ REQUIRED if getting 403 errors - export from logged-in browser
# YTDL_COOKIE_FILE=/path/to/cookies.txt

# Optional: Custom user agent (rotated automatically by default)
# YTDL_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0
